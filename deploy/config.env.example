# SFTP 接続情報のテンプレート。
# このファイルをコピーして deploy/config.env を作成し、実際の値を入れてください。
#   cp deploy/config.env.example deploy/config.env
# deploy/config.env は .gitignore 済みなのでコミットされません。

# SFTP サーバーのホスト名
SFTP_HOST="example.sakura.ne.jp"

# ポート（通常 22）
SFTP_PORT="22"

# ユーザー名
SFTP_USER="your-user"

# パスワード（" を含む場合はエスケープが必要です）
SFTP_PASS="your-password"

# サーバー側のアップロード先ディレクトリ（サイトの /renew/ ルートに対応）。
# 末尾スラッシュは付けても付けなくても構いません。
REMOTE_PATH="/home/your-user/www/renew"